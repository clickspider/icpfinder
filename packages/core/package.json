{
  "name": "@icpfinder/core",
  "version": "0.4.0",
  "description": "Core ICP discovery engine — archetype generation, candidate enrichment, streaming results.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./safe-fetch": {
      "types": "./dist/safe-fetch.d.ts",
      "default": "./dist/safe-fetch.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clickspider/icpfinder.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/clickspider/icpfinder/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/clickspider/icpfinder/issues"
  },
  "keywords": [
    "icp",
    "customer-discovery",
    "openai",
    "gemini",
    "streaming",
    "b2b"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "@icpfinder/providers": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
