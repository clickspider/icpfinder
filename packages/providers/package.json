{
  "name": "@icpfinder/providers",
  "version": "0.4.0",
  "description": "Swappable EmailProvider + LlmProvider implementations for icpfinder.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hunter": {
      "types": "./dist/hunter.d.ts",
      "default": "./dist/hunter.js"
    },
    "./gemini": {
      "types": "./dist/gemini.d.ts",
      "default": "./dist/gemini.js"
    },
    "./fake": {
      "types": "./dist/fake.d.ts",
      "default": "./dist/fake.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clickspider/icpfinder.git",
    "directory": "packages/providers"
  },
  "homepage": "https://github.com/clickspider/icpfinder/tree/main/packages/providers#readme",
  "bugs": {
    "url": "https://github.com/clickspider/icpfinder/issues"
  },
  "keywords": [
    "icpfinder",
    "gemini",
    "hunter",
    "llm-provider",
    "email-provider"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
