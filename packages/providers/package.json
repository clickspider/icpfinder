{
  "name": "@icpfinder/providers",
  "version": "0.1.0",
  "description": "Swappable EmailProvider + LlmProvider implementations for icpfinder.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./hunter": "./src/hunter.ts",
    "./gemini": "./src/gemini.ts",
    "./fake": "./src/fake.ts"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./hunter": {
        "types": "./dist/hunter.d.ts",
        "import": "./dist/hunter.js"
      },
      "./gemini": {
        "types": "./dist/gemini.d.ts",
        "import": "./dist/gemini.js"
      },
      "./fake": {
        "types": "./dist/fake.d.ts",
        "import": "./dist/fake.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clickspider/icpfinder.git",
    "directory": "packages/providers"
  },
  "homepage": "https://github.com/clickspider/icpfinder/tree/main/packages/providers#readme",
  "bugs": {
    "url": "https://github.com/clickspider/icpfinder/issues"
  },
  "keywords": ["icpfinder", "gemini", "hunter", "llm-provider", "email-provider"],
  "scripts": {
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
