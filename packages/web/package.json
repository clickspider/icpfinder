{
  "name": "@icpfinder/web",
  "version": "0.1.0",
  "description": "Next.js web app — streaming ICP discovery UI for icpfinder.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@icpfinder/core": "workspace:*",
    "@icpfinder/providers": "workspace:*",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.3.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^5.22.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
