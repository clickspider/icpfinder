# Copy to .env for local dev. SQLite needs no creds.
# Postgres. Local dev: spin up Neon free, Supabase, or `docker run postgres`.
# Production: Vercel Neon integration auto-injects this + DATABASE_URL_UNPOOLED.
# Unset DATABASE_URL entirely to disable persistence (app still streams via NoopRunRecorder).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/icpfinder"
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/icpfinder"

# Optional — leave unset to run providers in stub mode.
GEMINI_API_KEY=
HUNTER_API_KEY=

# Per-run hard cap (cents). Server refuses to start a run that
# wouldn't fit inside this budget at minimum candidate counts.
ICPFINDER_BUDGET_CAP_CENTS=200

# Daily per-IP cap (cents). In-memory by default; swap for Upstash
# in prod by setting UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN.
ICPFINDER_DAILY_CAP_CENTS=500
ICPFINDER_DAILY_RUNS=20
