{
  "name": "icpfinder",
  "version": "0.1.0",
  "private": true,
  "description": "Free, open-source first-customer-discovery tool for indie AI builders.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --concurrency=15",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "demo": "bun run scripts/demo.ts",
    "changeset": "changeset",
    "version-packages": "changeset version && bun install --lockfile-only",
    "release": "turbo run build --filter=@icpfinder/core --filter=@icpfinder/providers && changeset publish"
  },
  "dependencies": {
    "@icpfinder/core": "workspace:*",
    "@icpfinder/providers": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "bun@1.3.0",
  "engines": {
    "node": ">=20"
  }
}
